# Anthropic (optional). Without this, explanations fall back to a deterministic
# local template so the demo runs without secrets.
ANTHROPIC_API_KEY=

# CROO Agent Protocol (CAP) — optional. Without ALL of these set, Parley uses
# MockSettlementAdapter and the demo still runs end-to-end locally.
#
# Setup (one-time, via https://agent.croo.network dashboard):
#   1. Register a "requester" agent and a "provider" agent (two separate
#      agents/SDK keys — Parley plays both sides of the CAP order in this
#      batch so the full lifecycle can be demoed from one process).
#   2. Under the provider agent, register a service with
#      require_fund_transfer=true. This is required: it is the only mode in
#      which CAP accepts a per-negotiation price instead of a fixed service
#      price, which is how Parley's negotiated price reaches the chain.
#   3. Copy each agent's SDK key and the provider's AA wallet address.
#   4. CAP has no testnet — deposit a small amount of real USDC (Base
#      mainnet, see CROO_USDC_TOKEN_ADDRESS) into the requester agent's AA
#      wallet address, visible in the dashboard. Gas is sponsored by CROO's
#      paymaster, so only USDC is needed, never ETH. Keep negotiated demo
#      prices low (e.g. $1-5) to keep real-money exposure trivial.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_REQUESTER_SDK_KEY=
CROO_PROVIDER_SDK_KEY=
CROO_SERVICE_ID=
CROO_PROVIDER_WALLET_ADDRESS=
# Native USDC on Base mainnet (chain id 8453).
CROO_USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Shared secret between this server and anyone running
# run-cap-provider-listener.ts against it (see src/agents/seller). Generate
# any random string; it must match in both places. If you deploy this
# server, set the same value there too.
PARLEY_INTERNAL_KEY=

# Only needed when running run-cap-provider-listener.ts yourself, in ITS OWN
# .env (not this server's) — which agent policy to fetch, and where to fetch
# it from. Never put your real CROO credentials here on the server.
# PARLEY_SELLER_AGENT_ID=
# PARLEY_BASE_URL=http://localhost:3000
